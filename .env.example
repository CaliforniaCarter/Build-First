# ─────────────────────────────────────────────────────────────────────────────
# Real-API path. Copy to .env and fill in your key:
#
#   uv pip install -e ".[api]"
#   cp .env.example .env   &&   edit .env
#   uv run tb post --provider anthropic
#
# No key? Skip this file and use --provider terminal (the agent running the
# command becomes the engine). Your .env is gitignored — never commit a key.
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Model-agnostic: any Claude model id. sonnet is a good default; opus for max quality.
BF_MODEL=claude-sonnet-4-6
