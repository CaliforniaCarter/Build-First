# ─────────────────────────────────────────────────────────────────────────────
# DORMANT API PATH — not used by the overnight build.
#
# The walking skeleton runs with NO key: the TerminalProvider routes every
# reasoning step to the local agent (Claude Code) in the terminal. This file
# only matters when you want the automated re-eval path with the API:
#
#   uv pip install -e ".[api]"
#   cp .env.example .env  &&  edit .env
#   bf ablate --provider anthropic
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
BF_MODEL=claude-opus-4-8
